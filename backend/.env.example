# ===================================
# SoundWave Backend Configuration
# ===================================
# Copy this file to .env and fill in values

# Server
NODE_ENV=development
PORT=4000

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="postgresql://usuario:contraseña@ep-cool-db-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Cloudflare R2 Config
R2_ACCOUNT_ID="tu-cloudflare-account-id"
R2_ACCESS_KEY_ID="tu-access-key-id"
R2_SECRET_ACCESS_KEY="tu-secret-access-key"
R2_BUCKET_NAME="musica"
R2_PUBLIC_URL="https://pub-tu-url.r2.dev"

# JWT Secrets (generate strong random strings for production!)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Bcrypt
BCRYPT_SALT_ROUNDS=12
